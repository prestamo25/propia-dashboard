# Copy to .env.local and fill in. NEVER commit real values (.env* is gitignored).

# Supabase — a SECRET key (sb_secret_…, the new API key system; bypasses RLS,
# server-only, never exposed to the browser). Create a dedicated one in the
# dashboard: Project Settings → API → Secret keys → New secret key.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# Password-per-role gate. Each role has its own login password:
#   ADMIN_PASSWORD → "admin"  (Pablo / business: Brokers, Panorama, Reportes)
#   DEV_PASSWORD   → "dev"    (técnico superuser: the above + technical screens)
# SESSION_SECRET signs the role into the cookie (generate: openssl rand -hex 32).
ADMIN_PASSWORD=change-me
DEV_PASSWORD=change-me-too
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Cloudflare R2 (for the Técnico → Almacenamiento screen; lists objects to total
# storage per broker). Create a read+list API token in Cloudflare → R2 → Manage
# API Tokens. Server-only.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=propia-photos
