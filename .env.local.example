# Copy to .env.local and fill in. NEVER commit real values (.env* is gitignored).

# Supabase — the SERVICE ROLE key (bypasses RLS, server-only, never exposed to
# the browser). Get both from Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...

# Admin gate (shared password login).
# ADMIN_PASSWORD = what you type on the login screen.
# SESSION_SECRET = a long random string used to sign the session cookie
#   (generate one with:  openssl rand -hex 32  ).
ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-with-openssl-rand-hex-32
